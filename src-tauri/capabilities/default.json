{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for XClearp",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "allow-start-scan",
    "allow-start-clean",
    "allow-cancel-operation",
    "allow-get-groups",
    "allow-get-rules",
    "allow-update-rule",
    "allow-add-custom-rule",
    "allow-list-directory",
    "allow-get-disk-usage",
    "allow-start-disk-analysis",
    "allow-get-whitelist",
    "allow-update-whitelist",
    "allow-add-group",
    "allow-delete-group",
    "allow-delete-path",
    "allow-import-rules",
    "allow-clear-disk-analysis-cache",
    "allow-open-path",
    "allow-get-platform",
    "allow-check-disk-permissions",
    "allow-open-system-settings-pane",
    "allow-delete-rule",
    "allow-relaunch",
    "allow-list-apps",
    "allow-scan-app",
    "allow-uninstall-app",
    "allow-cancel-uninstall",
    "allow-get-icon-data-urls",
    "allow-retry-failed-items",
    "allow-batch-uninstall",
    "allow-get-failed-uninstalls",
    "allow-clear-failed-uninstalls",
    "allow-get-uninstall-state",
    "allow-scan-orphan-files",
    "allow-delete-orphan-files",
    "allow-list-startup-items",
    "allow-toggle-startup-item",
    "allow-remove-startup-item",
    "updater:default"
  ]
}
