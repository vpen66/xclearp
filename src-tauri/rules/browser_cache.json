[
  {
    "id": "chrome_cache",
    "name": "Google Chrome 缓存",
    "group": "browser_cache",
    "description": "Chrome 浏览器缓存文件",
    "platforms": ["macos", "linux"],
    "paths": [
      "~/Library/Caches/Google/Chrome/Default/Cache",
      "~/.cache/google-chrome/Default/Cache"
    ],
    "file_patterns": ["*"],
    "exclude_patterns": ["*.lock"],
    "min_age_hours": 0,
    "max_size_mb": null,
    "risk_level": "Safe",
    "enabled": true
  },
  {
    "id": "chrome_cache_win",
    "name": "Google Chrome 缓存",
    "group": "browser_cache",
    "description": "Chrome 浏览器缓存文件 (Windows)",
    "platforms": ["windows"],
    "paths": ["%LOCALAPPDATA%\\Google\\Chrome\\User Data\\Default\\Cache"],
    "file_patterns": ["*"],
    "exclude_patterns": ["*.lock"],
    "min_age_hours": 0,
    "max_size_mb": null,
    "risk_level": "Safe",
    "enabled": true
  },
  {
    "id": "firefox_cache",
    "name": "Firefox 缓存",
    "group": "browser_cache",
    "description": "Firefox 浏览器缓存文件",
