    "description": "Firefox 浏览器缓存文件 (Windows)",
    "platforms": ["windows"],
    "paths": ["%LOCALAPPDATA%\\Mozilla\\Firefox\\Profiles"],
    "file_patterns": ["*"],
    "exclude_patterns": ["*.lock", "*.sqlite", "*.sqlite-journal"],
    "min_age_hours": 0,
    "max_size_mb": null,
    "risk_level": "Safe",
    "enabled": true
  },
  {
    "id": "safari_cache",
