    "paths": [
      "~/Library/Caches/Firefox/Profiles",
      "~/.cache/mozilla/firefox"
    ],
    "file_patterns": ["*"],
    "exclude_patterns": ["*.lock", "*.sqlite", "*.sqlite-journal"],
    "min_age_hours": 0,
    "max_size_mb": null,
    "risk_level": "Safe",
    "enabled": true
  },
  {
    "id": "firefox_cache_win",
    "name": "Firefox 缓存",
